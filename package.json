{
  "name": "@arcolab/arcops",
  "version": "0.3.1",
  "type": "module",
  "description": "Agent-first ops cockpit CLI for the Arcops backend (Stripe revenue, traffic, GSC, UTM/funnels, customers, postmaster inbox).",
  "bin": {
    "arcops": "dist/arcops.mjs"
  },
  "files": [
    "dist/arcops.mjs"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "bun run build.ts",
    "dev": "bun --watch run src/main.ts --",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "gen:skill": "bun run scripts/gen-skill.ts",
    "check:skill": "bun run scripts/gen-skill.ts --check",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "cli",
    "saas",
    "ops",
    "stripe",
    "analytics",
    "inbox",
    "agent"
  ],
  "license": "MIT",
  "author": "arcolab",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/arcolabs/arcops.git"
  },
  "homepage": "https://github.com/arcolabs/arcops#readme",
  "bugs": {
    "url": "https://github.com/arcolabs/arcops/issues"
  },
  "dependencies": {
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/node": "^20",
    "typescript": "^5"
  }
}
